# Database Configuration (Supabase PostgreSQL)
# 
# ВАЖНО: Получите актуальный connection string из Supabase Dashboard:
# 1. Откройте https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/database
# 2. Скопируйте "Connection string" в режиме "Transaction" или "Session"
# 3. Замените [YOUR-PASSWORD] на ваш пароль базы данных
#
# Transaction pooler (порт 6543) - для коротких запросов (рекомендуется)
DATABASE_URL=postgresql://postgres.dnpjcxjjavzjmtfzlrip:1OSoLRpib7Tmd2Lu@aws-0-eu-north-1.pooler.supabase.com:6543/postgres

# Session pooler (порт 5432) - для длинных сессий
# DATABASE_URL=postgresql://postgres.dnpjcxjjavzjmtfzlrip:1OSoLRpib7Tmd2Lu@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# Direct connection (порт 5432) - без pooler (если pooler не работает)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Scraper Configuration
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=30

# Regions to scrape (comma-separated region codes)
# 54 - Новосибирская область
# 77 - Москва
# 50 - Московская область
TARGET_REGIONS=54,77,50

# Date range for initial scraping (YYYY-MM-DD)
SCRAPE_DATE_FROM=2026-01-25
SCRAPE_DATE_TO=2026-04-25

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/tenderlens.log

# Telegram Bot
# Получите токен через @BotFather в Telegram:
# 1. Отправьте /newbot
# 2. Укажите имя бота (например, TenderLens Bot)
# 3. Укажите username (например, tenderlens_bot)
# 4. Скопируйте токен и вставьте ниже
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Ваш Telegram User ID (для админских функций)
# Получите через @userinfobot
TELEGRAM_ADMIN_ID=your-admin-id-here
