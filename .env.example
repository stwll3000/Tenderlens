# Database Configuration (Supabase PostgreSQL)
# 1. Создайте проект на https://supabase.com
# 2. Перейдите в Settings > Database
# 3. Скопируйте Connection String (URI) в формате:
#    postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# 4. Вставьте строку подключения ниже:
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Опционально (для Supabase API, если понадобится):
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-key-here

# Scraper Configuration
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=30

# Regions to scrape (comma-separated region codes)
# 54 - Новосибирская область
# 77 - Москва
# 50 - Московская область
TARGET_REGIONS=54,77,50

# Date range for initial scraping (YYYY-MM-DD)
SCRAPE_DATE_FROM=2026-01-25
SCRAPE_DATE_TO=2026-04-25

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/tenderlens.log

# Telegram Bot (for future use)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ADMIN_ID=your-admin-id-here
